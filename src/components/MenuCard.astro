---
// Data
import menuData from "@/data/menu.json";

// Helpers

// Components
import CustomPicture from "./ui/CustomPicture.astro";
import Heading from "./ui/Heading.astro";
import { getCollection } from "astro:content";

const menuCollection = await getCollection(`menu`);
---

<ul>
  {
    menuCollection.map(({ data }) => {
      const { title, description, gallery, alt } = data;
      return (
        <li>
          <CustomPicture
            desktopURL={gallery.desktop}
            mobileURL={gallery.mobile}
            mobileHeight={gallery.mobile.height}
            mobileWidth={gallery.mobile.width}
            alt={alt}
            priority={false}
            class="menu__card-picture"
          />
          <div>
            <Heading title={title} tag="h3" size="h4" />
            <p>{description}</p>
          </div>
        </li>
      );
    })
  }
</ul>

<style>
  ul {
    margin-block-start: 85px;
  }

  ul > * + *::before {
    content: "";
    display: block;
    width: 100%;
    height: 1px;
    background-color: hsl(from var(--clr-neutral-0) h s l / 0.15);
    margin-block: 54px 24px;
  }

  li {
    text-align: center;
  }

  div {
    margin-block-start: 36px;
  }

  @media (min-width: 640px) {
    ul {
      max-width: 615px;
      margin-inline: auto;
    }

    ul > * + *::before {
      margin-block: 30px 32px;
      grid-column: 1 / -1;
    }

    li {
      display: grid;
      grid-template-columns: auto 1fr;
      column-gap: 62px;
      /* justify-items: center; */
      align-items: center;
      text-align: left;
    }

    div {
      margin-block-start: 0px;

      p {
        margin-block-start: 6px;
        max-width: 41ch;
        font-size: var(--fs-5);
      }
    }

    .menu__card-picture {
      display: block;
      position: relative;
      width: 128px;
      height: 96px;
    }

    .menu__card-picture::after {
      content: "";
      position: absolute;
      right: -32px;
      top: 30px;
      display: block;
      height: 1px;
      width: 32px;
      background-color: var(--clr-primary-brown-700);
    }
  }

  @media (min-width: 1000px) {
    ul {
      grid-column: 14 / -2;
    }
  }
</style>
