---
export const prerender = false;

// Images
import DecrementBtnLogo from "@/icons/icon-minus.svg";
import IncrementBtnLogo from "@/icons/icon-plus.svg";
import ArrowIcon from "@/icons/icon-arrow.svg";

// Components
import LinkOrButton from "./LinkOrButton.astro";
---

<section class="form-sect | grid-main" aria-labelledby="">
  <h2 class="sr-only">Make a reservation</h2>

  <form action="" class="form" id="form" novalidate>
    <div class="form__control">
      <label for="name"></label>
      <input
        type="text"
        id="name"
        name="name"
        placeholder="Name"
        aria-describedby="error-msg-name"
        required
      />
      <span
        id="error-msg-name"
        class="error-msg"
        aria-live="polite"
        data-error-for="name"></span>
    </div>
    <div class="form__control">
      <label for="email"></label>
      <input
        type="email"
        name="email"
        id="email"
        placeholder="Email"
        aria-describedby="error-msg-email"
        required
      />
      <span
        id="error-msg-email"
        class="error-msg"
        aria-live="polite"
        data-error-for="email"></span>
    </div>
    <fieldset class="form__control date">
      <legend><span>Pick a date</span></legend>
      <div class="grid-row">
        <label>
          <span class="sr-only">Day</span>
          <input
            id="day"
            name="day"
            type="text"
            inputmode="numeric"
            maxlength="2"
            placeholder="DD"
            aria-describedby="error-msg-date"
            required
          />
        </label>
        <label>
          <span class="sr-only">Month</span>
          <input
            id="month"
            name="month"
            type="text"
            inputmode="numeric"
            maxlength="2"
            placeholder="MM"
            aria-describedby="error-msg-date"
            required
          />
        </label>
        <label>
          <span class="sr-only">Year</span>
          <input
            id="year"
            name="year"
            type="text"
            inputmode="numeric"
            maxlength="4"
            placeholder="YYYY"
            aria-describedby="error-msg-date"
            required
          />
        </label>
        <span
          class="error-msg"
          id="error-msg-date"
          aria-live="polite"
          data-error-for="day"></span>
      </div>
    </fieldset>
    <fieldset class="form__control time">
      <legend><span>Pick a time</span></legend>
      <div class="grid-row">
        <label>
          <span class="sr-only">Hour</span>
          <input
            id="hour"
            name="hour"
            type="text"
            inputmode="numeric"
            maxlength="2"
            placeholder="09"
            aria-describedby="error-msg-time"
            required
          />
        </label>
        <label>
          <span class="sr-only">Minute</span>
          <input
            id="minute"
            name="minute"
            type="text"
            inputmode="numeric"
            maxlength="2"
            placeholder="00"
            aria-describedby="error-msg-time"
            required
          />
        </label>

        <label for="meridiem"></label>
        <div class="custom-select">
          <button
            class="select-trigger"
            aria-label="Choose AM or PM"
            aria-haspopup="listbox"
            aria-expanded="false"
            type="button"
          >
            <span class="selected-value">AM</span>
            <ArrowIcon class="arrow-icon" />
          </button>
          <ul class="select-options" role="listbox">
            <li
              class="select-choices"
              role="option"
              aria-selected="true"
              data-option-one
              tabindex="0"
            >
              AM
            </li>
            <li
              class="select-choices"
              role="option"
              tabindex="0"
              data-option-two
            >
              PM
            </li>
          </ul>
          <input type="hidden" name="meridiem" id="meridiem" value="AM" />
        </div>
        <span
          class="error-msg"
          id="error-msg-time"
          aria-live="polite"
          data-error-for="minute"></span>
      </div>
    </fieldset>
    <div class="form__control stepper">
      <button
        class="decrement-btn"
        type="button"
        aria-label="Decrease people"
        aria-controls="people-input"
      >
        <DecrementBtnLogo class="decrement-logo" />
      </button>
      <span class="stepper-label" id="count" aria-label="polite">4 People</span>
      <button
        class="increment-btn"
        type="button"
        aria-label="Increase people"
        aria-controls="people-input"
      >
        <IncrementBtnLogo class="increment-logo" />
      </button>
      <input
        type="number"
        name="count"
        id="people-input"
        class="sr-only"
        min="1"
        value="4"
        inputmode="numeric"
      />
    </div>
    <LinkOrButton
      as="button"
      text="Make reservation"
      variant="dark"
      type="submit"
      class="btn--form"
    />
  </form>
</section>

<style>
  .form-sect {
    position: relative;
    height: 535px;
    background-color: var(--clr-neutral-0);
  }

  .form {
    grid-column: 2 / -2;
    position: absolute;
    top: clamp(-500px, calc(161.216px - 78.991vw), -130px);
    display: grid;
    gap: 34px;
    padding: 32px;

    background-color: var(--clr-neutral-0);
    box-shadow: 0 75px 100px -50px var(--clr-box-shadow);
  }

  .form .btn {
    width: 100%;
  }

  fieldset {
    display: grid;
    gap: 8px;
    border: 0px;
    padding: 0px;
  }

  legend {
    padding: 0px;
    padding-block-end: 8px;
  }

  .grid-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  input {
    border: 0;
    border-bottom: 1px solid var(--clr-neutral-200);
    width: 100%;
    max-width: 100%;
    padding-block-end: 14px;
    padding-inline-start: 16px;
  }

  select {
    border: 0px;
    padding: 0px;
    border-bottom: 1px solid var(--clr-neutral-200);
    background: transparent;
    width: 100%;
    height: 100%;

    padding-block-end: 14px;
    padding-inline-start: 16px;
  }

  /* Validation */

  .error-msg {
    grid-column: 1 / 3;
    grid-row: 2 / 3;
    font-weight: var(--fw-600);
    font-size: 0.75rem;
    color: var(--clr-secondary-red-500);
  }

  .error-input {
    border-bottom: 1px solid var(--clr-secondary-red-500);
    color: var(--clr-secondary-red-500);

    &::placeholder {
      color: var(--clr-secondary-red-500);
      opacity: 0.5;
    }
  }

  .error-legend {
    color: var(--clr-secondary-red-500);
  }

  /* Experiment */

  .stepper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0px 16px 14px;
    border-bottom: 1px solid var(--clr-neutral-200);
  }

  .increment-btn,
  .decrement-btn {
    padding: 10px;
    border: 0px;
    background-color: transparent;
    cursor: pointer;
  }

  .stepper-label {
    font-weight: var(--fw-700);
    font-size: var(--fs-4);
  }

  .custom-select {
    grid-column: 3 / 4;
    grid-row: 1 / 2;
    position: relative;
    width: 100%;
  }

  .select-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    width: 100%;
    padding: 0px 0px 14px 16px;
    border: 0px;
    border-bottom: 1px solid var(--clr-neutral-200);
    background-color: transparent;

    cursor: pointer;
  }

  .arrow-icon {
    transition: transform ease-in-out 0.2s;
  }

  [aria-expanded="true"] .arrow-icon {
    transform: rotate(180deg);
  }

  .select-options {
    position: absolute;
    right: 0;
    left: 0;
    display: none;
  }

  .select-choices {
    cursor: pointer;
  }

  [aria-expanded="true"] ~ .select-options {
    outline: 1px solid black;
    display: block;
  }

  .highlighted {
    border-bottom: 1px solid red;
  }

  @media (min-width: 640px) {
    .form-sect {
      height: 435px;
    }

    .form {
      top: clamp(-190px, calc(391.216px - 78.991vw), -130px);

      padding: 48px;
    }

    fieldset {
      display: grid;
      gap: 45px;
      align-items: center;
      grid-auto-flow: column;
    }

    legend {
      display: contents;
      grid-column: 1 / 2;
    }

    .select-trigger {
      gap: 2px;
    }

    .error-msg {
      grid-column: 1 / 4;
      text-align: center;
    }
  }

  @media (min-width: 1000px) {
    .form {
      grid-column: 14 / -1;
      max-width: 540px;
      top: clamp(-342px, calc(638px - 68.991vw), -200px);

      /* top: -342px; */
    }
  }
</style>

<script>
  import { actions, isInputError } from "astro:actions";
  import { object } from "astro:schema";

  const form = document.querySelector<HTMLFormElement>(`.form`);

  form?.addEventListener(`submit`, async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const { error } = await actions.bookingForm(formData);

    clearAllErrors();

    if (isInputError(error)) {
      for (const [fieldName, message] of Object.entries(error.fields)) {
        console.log(error.fields);
        const firstErrorMessage = message[0];
        setFieldError(fieldName, firstErrorMessage);
      }
    }
  });

  function setFieldError(fieldName: string, message: string | null) {
    const inputEl = document.querySelector<HTMLElement>(
      `input[name="${fieldName}"]`
    );

    inputEl?.classList.add(`error-input`);
    const fieldset = inputEl?.closest(`fieldset`);
    const legendEl = fieldset?.querySelector(`legend`);
    legendEl?.classList.add(`error-legend`);

    const errorEl = document.querySelector<HTMLSpanElement>(
      `[data-error-for="${fieldName}"]`
    );
    if (!errorEl) return;
    errorEl.textContent = message ?? "";
  }

  function clearAllErrors() {
    document
      .querySelectorAll(`[data-error-for]`)
      .forEach((el) => (el.textContent = ""));
    document
      .querySelectorAll<HTMLInputElement>(`input`)
      .forEach((input) => input.classList.remove(`error-input`));
    document
      .querySelectorAll<HTMLLegendElement>(`legend`)
      .forEach((leg) => leg.classList.remove(`error-legend`));
  }

  // Stepper Code
  const decrementBtn =
    document.querySelector<HTMLButtonElement>(`.decrement-btn`)!;
  const incrementBtn =
    document.querySelector<HTMLButtonElement>(`.increment-btn`)!;
  const countLabel = document.querySelector<HTMLSpanElement>(`.stepper-label`)!;
  const peopleInput =
    document.querySelector<HTMLInputElement>(`#people-input`)!;
  let count = Number(peopleInput.value) || 1;
  let min = Number(peopleInput.getAttribute(`min`)) || 1;

  console.log(count);

  function updateDisplay() {
    countLabel.textContent = `${count} ${count === 1 ? `Person` : `People`}`;
    peopleInput.value = String(count);

    if (count <= 0) {
      decrementBtn.disabled;
    }
  }

  decrementBtn.addEventListener(`click`, () => {
    if (count > min) {
      count--;
      updateDisplay();
    }
  });

  incrementBtn.addEventListener(`click`, () => {
    count++;
    updateDisplay();
  });

  // Custom Meridiem Code
  const customSelectWrapperEl =
    document.querySelector<HTMLDivElement>(`.custom-select`);
  const selectTriggerEl =
    document.querySelector<HTMLButtonElement>(`.select-trigger`);
  const selectOptionsListEl =
    document.querySelector<HTMLElement>(`.select-options`);
  const selectValueEl =
    document.querySelector<HTMLSpanElement>(`.selected-value`);
  const meridiemInputEl = document.querySelector<HTMLInputElement>(`#meridiem`);
  const selectOptionEls =
    document.querySelectorAll<HTMLLIElement>(`.select-choices`);

  let currentFocus = Array.from(selectOptionEls).findIndex(
    (opt) => opt.getAttribute(`aria-selected`) === `true`
  );

  selectTriggerEl?.addEventListener(`click`, () => {
    const isExpanded = selectTriggerEl.getAttribute(`aria-expanded`) === `true`;
    selectTriggerEl.setAttribute(`aria-expanded`, String(!isExpanded));
    if (isExpanded) {
      selectOptionsListEl?.focus();
      highlightOption(currentFocus);
    }
  });

  document.addEventListener(`click`, (e) => {
    const target = e.target;

    if (!(target instanceof Node)) return;

    if (!customSelectWrapperEl?.contains(target)) {
      closeDropdown();
    }
  });

  selectOptionEls.forEach((opt, index) =>
    opt.addEventListener(`click`, () => {
      selectOption(index);
    })
  );

  function selectOption(index: any) {
    selectOptionEls.forEach((opt, i) => {
      if (i === index) {
        opt.setAttribute(`aria-selected`, `true`);
        selectValueEl!.textContent = opt.textContent;
        meridiemInputEl!.value = opt.textContent.trim();
        currentFocus = i;
        console.log(meridiemInputEl?.value);
      } else {
        opt.setAttribute(`aria-selected`, `false`);
      }
    });
    closeDropdown();
    selectTriggerEl?.focus();
  }

  function highlightOption(index: number) {
    removeHighlight();
    const el = selectOptionEls[index];
    if (el) {
      el.classList.add(`highlighted`);
      el.scrollIntoView({ block: `nearest` });
    }
  }

  function removeHighlight() {
    selectOptionEls.forEach((opt) => opt.classList.remove(`highlighted`));
  }

  function closeDropdown() {
    selectTriggerEl?.setAttribute(`aria-expanded`, `false`);
    removeHighlight();
  }

  customSelectWrapperEl?.addEventListener(`keydown`, (e) => {
    if (
      selectTriggerEl?.getAttribute(`aria-expanded`) === `false` &&
      (e.key === `ArrowDown` || e.key === `ArrowUp`)
    ) {
      selectTriggerEl.setAttribute(`aria-expanded`, `true`);
      highlightOption(currentFocus);
      e.preventDefault();
      return;
    }

    switch (e.key) {
      case `ArrowDown`:
        currentFocus = (currentFocus + 1) % selectOptionEls.length;
        highlightOption(currentFocus);
        e.preventDefault();
        console.log(e.key);
        break;
      case `ArrowUp`:
        currentFocus =
          (currentFocus - 1 + selectOptionEls.length) % selectOptionEls.length;
        highlightOption(currentFocus);
        e.preventDefault();
        console.log(e.key);

        break;
      case `Enter`:
      case " ":
        if (selectTriggerEl?.getAttribute(`aria-expanded`) === `true`) {
          selectOption(currentFocus);
          e.preventDefault();
          console.log(e.key);
        }
        break;
      case `Escape`:
        closeDropdown();
        e.preventDefault();
        console.log(e.key);

        break;
    }
  });
</script>
