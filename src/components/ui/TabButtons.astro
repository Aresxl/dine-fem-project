---
const { id, controls, selected = false } = Astro.props;
---

<button
  id={id}
  role="tab"
  aria-controls={controls}
  aria-selected={selected}
  class="tab__button"
>
  <slot />
</button>

<style>
  .tab__button {
    display: flex;
    flex-direction: column;
    align-items: center;
    border: 0;
    padding: 0px;
    background-color: transparent;
    font-weight: var(--fw-600);
    font-size: 1.0625rem;
    text-transform: uppercase;
    line-height: 28px;
    letter-spacing: 2.5px;
    color: hsl(from var(--clr-neutral-400) h s l / 0.5);
    cursor: pointer;
  }

  .tab__button--active {
    color: var(--clr-neutral-400);

    &::after {
      content: "";
      display: block;
      height: 1px;
      width: 48px;
      background-color: var(--clr-primary-brown-700);
    }
  }

  @media (min-width: 1000px) {
    .tab__button {
      display: block;
      position: relative;

      &::after {
        position: absolute;
        z-index: -1;
        top: 11px;
        left: -15px;
        transform: translateX(-100%);
        width: 95px;
      }
    }
  }
</style>
